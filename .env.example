# ─── Strava OAuth ────────────────────────────────────────────────────
# Register an app at https://www.strava.com/settings/api
#   - Authorization Callback Domain:
#       prod    → your domain (e.g. reko.run)
#       local   → localhost   (use a SECOND Strava account; you can
#                              only have one API app per account)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# ─── Session encryption ──────────────────────────────────────────────
# 32+ random chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─── Database ────────────────────────────────────────────────────────
# Set this when running `pnpm dev` directly on the host. Format:
#   postgres://user:password@host:port/dbname
#
# Recommended local dev setups:
#
#   A. Full stack via docker compose:
#        docker compose up
#      (compose injects DATABASE_URL itself — leave this blank)
#
#   B. Compose-managed Postgres + host hot-reload:
#        docker compose up postgres
#        DATABASE_URL=postgres://reko:reko_local_dev@localhost:5432/reko
#        pnpm dev
#
#   C. Coolify production: Coolify injects this from the Postgres
#      service's internal hostname. Leave the var unset locally if
#      you don't run `pnpm db:studio` etc.
DATABASE_URL=

# ─── Optional ────────────────────────────────────────────────────────
# Override the postgres password used by docker-compose. If unset,
# defaults to "reko_local_dev". Only matters for local docker stack.
# POSTGRES_PASSWORD=
