# ─── Strava OAuth ────────────────────────────────────────────────────
# Register an app at https://www.strava.com/settings/api
#   - Authorization Callback Domain:
#       prod    → your domain (e.g. reko.run)
#       local   → localhost   (use a SECOND Strava account; you can
#                              only have one API app per account)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# ─── Session encryption ──────────────────────────────────────────────
# 32+ random chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─── Database ────────────────────────────────────────────────────────
# Set this when running `pnpm dev` directly on the host. Format:
#   postgres://user:password@host:port/dbname
#
# Recommended local dev setups:
#
#   A. Full stack via docker compose:
#        docker compose up
#      (compose injects DATABASE_URL itself — leave this blank)
#
#   B. Compose-managed Postgres + host hot-reload:
#        docker compose up postgres
#        DATABASE_URL=postgres://reko:reko_local_dev@localhost:5432/reko
#        pnpm dev
#
#   C. Coolify production: Coolify injects this from the Postgres
#      service's internal hostname. Leave the var unset locally if
#      you don't run `pnpm db:studio` etc.
DATABASE_URL=

# ─── Strava Webhooks (optional, prod-only) ───────────────────────────
# Reko can receive live activity updates from Strava via push
# subscriptions instead of polling. Skip this entirely on localhost —
# Strava requires a public HTTPS callback URL, so dev users just hit
# the "Resync" button to pull fresh activities.
#
# To enable in prod:
#   1. Set both vars below.
#   2. Run once:  pnpm exec tsx scripts/register-webhook.ts subscribe
#   3. Strava will GET your callback URL, see WEBHOOK_VERIFY_TOKEN, and
#      start POSTing activity events.
#
# WEBHOOK_VERIFY_TOKEN: any random string. Used to verify the GET
# handshake during subscription registration. Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
WEBHOOK_VERIFY_TOKEN=

# WEBHOOK_CALLBACK_URL: public HTTPS URL of the webhook endpoint.
# Strava rejects http:// and unreachable hosts. Examples:
#   https://reko.run/api/strava/webhook
#   https://your-tunnel.trycloudflare.com/api/strava/webhook
WEBHOOK_CALLBACK_URL=

# ─── Optional ────────────────────────────────────────────────────────
# Override the postgres password used by docker-compose. If unset,
# defaults to "reko_local_dev". Only matters for local docker stack.
# POSTGRES_PASSWORD=
