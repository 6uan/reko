# ════════════════════════════════════════════════════════════════════
#  Reko environment
#
#    SHARED     — needed everywhere (local dev + prod)
#    LOCAL ONLY — only when developing on your machine
#    PROD ONLY  — only on your public deploy
#
#  Local dev reads this file. On Coolify (prod) you set these in the
#  dashboard's "Environment Variables" tab instead — this file is ignored
#  there and is never baked into the image.
# ════════════════════════════════════════════════════════════════════


# ─── SHARED ──────────────────────────────────────────────────────────

# Strava OAuth. Register an app at https://www.strava.com/settings/api,
# then copy the Client ID + Secret here.
#
# Authorization Callback Domain (hostname only — no protocol, no path):
#   local → localhost        (use a SECOND Strava account; you only get
#                             one API app per account)
#   prod  → your domain      e.g. reko.run
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Session-cookie encryption key. 32+ random chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Postgres connection string: postgres://user:password@host:port/dbname
#   • `pnpm dev` (host dev)  → set it here, pointing at localhost:
#                              postgres://reko:reko_local_dev@localhost:5432/reko
#   • `docker compose up`    → leave blank; compose injects it
#   • Coolify (prod)         → leave blank; Coolify injects it
DATABASE_URL=


# ─── LOCAL ONLY ──────────────────────────────────────────────────────

# Skip Strava OAuth and auto-login as an existing DB user — handy when you
# can't complete the OAuth flow (e.g. responsive-design tools). The user
# must already exist in your local DB. NEVER enable in production.
# DEV_AUTH_BYPASS=true
# DEV_USER_ID=1

# Override the docker-compose Postgres password (defaults to reko_local_dev).
# Only affects the local `db` container.
# POSTGRES_PASSWORD=


# ─── PROD ONLY ───────────────────────────────────────────────────────

# Strava webhooks — live activity push instead of the manual Resync button.
# Requires a public HTTPS callback, so this is prod-only; skip it locally.
# Enable in prod:
#   1. Set both vars below.
#   2. Run once:  pnpm exec tsx scripts/register-webhook.ts subscribe
#
# WEBHOOK_VERIFY_TOKEN: any random string; verifies the subscription
# handshake. Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# WEBHOOK_VERIFY_TOKEN=
#
# WEBHOOK_CALLBACK_URL: public HTTPS URL of the webhook endpoint.
# WEBHOOK_CALLBACK_URL=https://your-domain/api/strava/webhook
